{
  "name": "calorie-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 7001",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test -c testing/automation/playwright/playwright.config.ts",
    "test:e2e:meals": "playwright test -c testing/automation/playwright/playwright.config.ts --grep @meals",
    "test:e2e:weight": "playwright test -c testing/automation/playwright/playwright.config.ts --grep @weight",
    "test:e2e:history": "playwright test -c testing/automation/playwright/playwright.config.ts --grep @history",
    "lint": "oxlint -c oxlint.json --vue-plugin src vite.config.ts capacitor.config.ts",
    "format": "oxfmt -c oxfmt.json --write src vite.config.ts capacitor.config.ts",
    "format:check": "oxfmt -c oxfmt.json --check src vite.config.ts capacitor.config.ts",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.1.1",
    "@capacitor/core": "^7.1.1",
    "@capacitor/ios": "^7.1.1",
    "@supabase/supabase-js": "^2.101.1",
    "dexie": "^4.0.11",
    "uplot": "^1.6.32",
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.2.12"
  }
}
